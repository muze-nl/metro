{
  "name": "@muze-nl/metro-oauth2",
  "version": "0.3.4",
  "description": "oauth2 middleware for @muze-nl/metro",
  "type": "module",
  "main": "src/browser.mjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "tap test/*.mjs",
    "build": "esbuild --bundle src/browser.mjs --outfile=dist/browser.min.js --sourcemap --minify",
    "build-dev": "esbuild --bundle src/browser.mjs --outfile=dist/browser.js --sourcemap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-nl/metro-oauth2.git"
  },
  "author": "auke@muze.nl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/muze-nl/metro-oauth2/issues"
  },
  "homepage": "https://github.com/muze-nl/metro-oauth2/#readme",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tap": "^16.0.1"
  },
  "dependencies": {
    "@muze-nl/assert": "^0.1.1",
    "@muze-nl/metro": "^0.5.4",
    "dpop": "^1.4.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "/src",
    "/dist",
    "/LICENSE",
    "/README.md"
  ],
  "source": [
    "src/browser.mjs"
  ],
  "targets": {
    "default": {
      "distDir": "./dist",
      "optimize": true
    },
    "main": false
  }
}
