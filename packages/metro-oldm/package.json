{
  "name": "@muze-nl/metro-oldm",
  "version": "0.4.1",
  "description": "linked data middleware for @muze-nl/metro",
  "type": "module",
  "source": [
    "src/browser.mjs"
  ],
  "main": "src/index.mjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "tap --disable-coverage --jobs=1 test/*.mjs",
    "tap": "tap",
    "build": "esbuild src/browser.mjs --outfile=dist/browser.min.js --bundle --minify --sourcemap",
    "build-dev": "esbuild src/browser.mjs --outfile=dist/browser.js --bundle --sourcemap",
    "build:dev": "esbuild src/browser.mjs --outfile=dist/browser.js --bundle --sourcemap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-nl/metro.git",
    "directory": "packages/metro-oldm"
  },
  "author": "auke@muze.nl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/muze-nl/metro/issues"
  },
  "homepage": "https://github.com/muze-nl/metro/tree/main/packages/metro-oldm#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tap": "^21.7.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "/src",
    "/dist",
    "/docs",
    "/LICENSE",
    "/README.md",
    "/MUZE_ALIGNMENT.md"
  ],
  "dependencies": {
    "@muze-nl/oldm": "^0.7.1"
  },
  "targets": {
    "default": {
      "distDir": "./dist",
      "optimize": true
    },
    "main": false
  },
  "exports": {
    ".": "./src/index.mjs",
    "./browser": "./src/browser.mjs",
    "./browser.mjs": "./src/browser.mjs",
    "./oldmmw": "./src/oldmmw.mjs",
    "./oldmmw.mjs": "./src/oldmmw.mjs",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./src/browser.mjs",
    "./dist/browser.js",
    "./dist/browser.min.js"
  ]
}
