{
  "name": "@muze-nl/metro",
  "version": "0.8.0",
  "description": "Beginner-friendly combined Metro package",
  "type": "module",
  "source": [
    "src/browser.mjs",
    "src/everything.mjs"
  ],
  "main": "src/index.mjs",
  "scripts": {
    "test": "tap --disable-coverage --jobs=1 test/*.mjs",
    "tap": "tap",
    "build-dev": "esbuild --bundle src/browser.mjs --outfile=dist/browser.js --sourcemap; esbuild --bundle src/everything.mjs --outfile=dist/everything.js --sourcemap",
    "build": "esbuild --bundle src/browser.mjs --outfile=dist/browser.min.js --minify --sourcemap; esbuild --bundle src/everything.mjs --outfile=dist/everything.min.js --minify --sourcemap",
    "build:dev": "esbuild --bundle src/browser.mjs --outfile=dist/browser.js --sourcemap; esbuild --bundle src/everything.mjs --outfile=dist/everything.js --sourcemap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-nl/metro.git",
    "directory": "packages/metro"
  },
  "author": "auke@muze.nl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/muze-nl/metro/issues"
  },
  "homepage": "https://github.com/muze-nl/metro/tree/main/packages/metro#readme",
  "devDependencies": {
    "eslint": "^10.5.0",
    "tap": "^21.7.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "/src",
    "/dist",
    "/LICENSE",
    "/README.md",
    "/docs"
  ],
  "exports": {
    ".": "./src/index.mjs",
    "./browser": "./src/browser.mjs",
    "./browser.mjs": "./src/browser.mjs",
    "./everything": "./src/everything.mjs",
    "./everything.mjs": "./src/everything.mjs",
    "./src/metro.mjs": "./src/metro.mjs",
    "./src/api.mjs": "./src/api.mjs",
    "./src/hashparams.mjs": "./src/hashparams.mjs",
    "./src/tracegraph.mjs": "./src/tracegraph.mjs",
    "./src/mw/json.mjs": "./src/mw/json.mjs",
    "./src/mw/thrower.mjs": "./src/mw/thrower.mjs",
    "./src/mw/getdata.mjs": "./src/mw/getdata.mjs",
    "./src/mw/retry.mjs": "./src/mw/retry.mjs",
    "./src/mw/timeout.mjs": "./src/mw/timeout.mjs",
    "./src/mw/abort.mjs": "./src/mw/abort.mjs",
    "./src/mw/backoff.mjs": "./src/mw/backoff.mjs",
    "./src/mw/echo.mock.mjs": "./src/mw/echo.mock.mjs",
    "./src/mw/error.mock.mjs": "./src/mw/error.mock.mjs",
    "./mw/json.mjs": "./src/mw/json.mjs",
    "./mw/thrower.mjs": "./src/mw/thrower.mjs",
    "./mw/getdata.mjs": "./src/mw/getdata.mjs",
    "./mw/retry.mjs": "./src/mw/retry.mjs",
    "./mw/timeout.mjs": "./src/mw/timeout.mjs",
    "./mw/abort.mjs": "./src/mw/abort.mjs",
    "./mw/backoff.mjs": "./src/mw/backoff.mjs",
    "./mw/echo.mock.mjs": "./src/mw/echo.mock.mjs",
    "./mw/error.mock.mjs": "./src/mw/error.mock.mjs",
    "./src/browser.mjs": "./src/browser.mjs",
    "./src/everything.mjs": "./src/everything.mjs",
    "./dist/browser.js": "./dist/browser.js",
    "./dist/browser.min.js": "./dist/browser.min.js",
    "./dist/everything.js": "./dist/everything.js",
    "./dist/everything.min.js": "./dist/everything.min.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@muze-nl/metro-core": "^0.8.0",
    "@muze-nl/metro-api": "^0.8.0",
    "@muze-nl/metro-middleware": "^0.8.0",
    "@muze-nl/metro-trace": "^0.8.0",
    "@muze-nl/metro-hashparams": "^0.8.0",
    "@muze-nl/metro-formdata": "^0.8.0"
  }
}
