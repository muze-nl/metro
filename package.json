{
  "name": "metro-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Metro and related middleware packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test -w @muze-nl/metro",
    "test:oauth2": "npm run test -w @muze-nl/metro-oauth2",
    "build": "npm run build --workspaces --if-present",
    "build:dev": "npm run build-dev --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "tap": "^21.7.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-nl/metro.git"
  },
  "license": "MIT",
  "overrides": {
    "test-exclude": {
      "glob": "^13.0.6"
    }
  }
}
